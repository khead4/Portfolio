=\"https://www.w3schools.com/aws/index.php\" target=\"_top\" title=\"AWS Tutorial\">\n            AWS\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/cybersecurity/index.php\" target=\"_top\" title=\"Cyber security Tutorial\">\n            CYBERSECURITY\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/datascience/default.asp\" target=\"_top\" title=\"Data science Tutorial\">\n            DATA SCIENCE\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/programming/index.php\" target=\"_top\" title=\"Introduction to Programming\">\n            INTRO TO PROGRAMMING\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/htmlcss/default.asp\" target=\"_top\" title=\"Introduction to HTML &amp; CSS\">\n            HTML &amp; CSS\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/bash/index.php\" target=\"_top\" title=\"Bash Tutorial\">\n            BASH\n          </a>\n<a class=\"ga-nav stnb-btn\" href=\"https://www.w3schools.com/rust/index.php\" target=\"_top\" title=\"Rust Tutorial\">\n            RUST\n          </a>\n</div>\n<div aria-label=\"Secondary nav left scroll\" class=\"stnb-scroll-btn stnb-left-scroll-btn\" role=\"button\" style=\"display: none\">\n<span class=\"stnb-icon\">\u276e</span>\n</div>\n<div aria-label=\"Secondary nav right scroll\" class=\"stnb-scroll-btn stnb-right-scroll-btn\" role=\"button\" style=\"display: none\">\n<span class=\"stnb-icon\">\u276f</span>\n</div>\n</div>\n<div id=\"googleSearch\">\n<div class=\"gcse-search\"></div>\n</div>\n</div>";
  
  // Helper function to check if element exists by ID
  function elementExists(id) {
    return document.getElementById(id) !== null;
  }
  
  // Helper function to check if link element exists by href
  function linkExistsByHref(href) {
    var links = document.getElementsByTagName('link');
    for (var i = 0; i < links.length; i++) {
      if (links[i].href === href || links[i].getAttribute('href') === href) {
        return true;
      }
    }
    return false;
  }
  
  // Helper function to inject fonts
  function injectFonts(fontsData) {
    if (!fontsData || !Array.isArray(fontsData)) return;
    
    var head = document.head || document.getElementsByTagName('head')[0];
    if (!head) return;
    
    fontsData.forEach(function(fontData) {
      var fontId = fontData.id;
      var fontUrl = fontData.url;
      
      // Check if font is already injected by ID
      if (elementExists(fontId)) {
        return;
      }
      
      // Check if font link already exists by href
      if (linkExistsByHref(fontUrl)) {
        return;
      }
      
      // Create and inject font preload link
      var link = document.createElement('link');
      link.id = fontId;
      link.rel = 'preload';
      link.href = fontUrl;
      link.as = 'font';
      link.type = 'font/woff2';
      link.crossOrigin = '';
      head.appendChild(link);
    });
  }
  
  // Helper function to inject CSS and return a Promise that resolves when loaded
  function injectCSS(cssUrl) {
    var cssId = 'tnb-main-styles';
    
    // Check if CSS is already injected
    if (elementExists(cssId)) {
      // If already loaded, return resolved promise
      return Promise.resolve();
    }
    
    var head = document.head || document.getElementsByTagName('head')[0];
    if (!head) return Promise.reject(new Error('Head element not found'));
    
    // Create and inject CSS link
    var link = document.createElement('link');
    link.id = cssId;
    link.rel = 'stylesheet';
    link.href = cssUrl;
    
    // Return a Promise that resolves when CSS is loaded
    return new Promise(function(resolve, reject) {
      var resolved = false;
      var timeoutId = null;
      
      var resolveOnce = function() {
        if (!resolved) {
          resolved = true;
          if (timeoutId) clearTimeout(timeoutId);
          resolve();
        }
      };
      
      var rejectOnce = function(error) {
        if (!resolved) {
          resolved = true;
          if (timeoutId) clearTimeout(timeoutId);
          reject(error);
        }
      };
      
      link.onload = resolveOnce;
      link.onerror = function() {
        rejectOnce(new Error('Failed to load CSS: ' + cssUrl));
      };
      
      // For older browsers that don't fire onload for stylesheets
      // Check if stylesheet is loaded by checking if it has rules
      var checkLoaded = function() {
        if (resolved) return;
        
        try {
          if (link.sheet && link.sheet.cssRules && link.sheet.cssRules.length >= 0) {
            resolveOnce();
          } else {
            timeoutId = setTimeout(checkLoaded, 10);
          }
        } catch (e) {
          // Cross-origin stylesheets throw errors, but onload should fire
          // Continue checking
          timeoutId = setTimeout(checkLoaded, 10);
        }
      };
      
      // Start checking after a short delay
      timeoutId = setTimeout(checkLoaded, 10);
      
      head.appendChild(link);
    });
  }
  
  // Helper function to inject JS
  function injectJS(jsUrl) {
    var jsId = 'tnb-main-scripts';
    
    // Check if JS is already injected
    if (elementExists(jsId)) {
      return;
    }
    
    var head = document.head || document.getElementsByTagName('head')[0];
    if (!head) return;
    
    // Create and inject script tag
    var script = document.createElement('script');
    script.id = jsId;
    script.src = jsUrl;
    script.async = true;
    head.appendChild(script);
  }
  
  // Helper function to get or create top-nav-bar-wrapper
  function getOrCreateWrapper() {
    var wrapper = document.getElementById('top-nav-bar-wrapper');
    
    if (!wrapper) {
      // Create wrapper element
      wrapper = document.createElement('div');
      wrapper.id = 'top-nav-bar-wrapper';
      
      // Insert right after body tag
      var body = document.body;
      if (body && body.firstChild) {
        body.insertBefore(wrapper, body.firstChild);
      } else if (body) {
        body.appendChild(wrapper);
      }
    }
    
    return wrapper;
  }
  
  // Helper function to inject HTML content
  function injectHTML(htmlContent) {
    var wrapper = getOrCreateWrapper();
    if (wrapper && htmlContent) {
      wrapper.innerHTML = htmlContent;
    }
  }
  
  // Main initialization function
  function initialize() {
    var assetsBaseUrl = 'https://nav.w3schools.com/plugin/';
    var version = '1.0.93';
    
    // Inject fonts from precached data
    injectFonts(PRECACHED_FONTS);
    
    // Inject JS (async, doesn't need to wait)
    injectJS(assetsBaseUrl + 'main.js?v=' + version);
    
    // Helper function to initialize TopNavBar after HTML is injected
    function initTopNavBar() {
      // Wait for TopNavBar to be available (script loads asynchronously)
      function tryInit() {
        if (typeof TopNavBar !== 'undefined' && typeof TopNavBar.init === 'function') {
          TopNavBar.init();
        } else {
          // Retry after a short delay if TopNavBar is not yet loaded
          setTimeout(tryInit, 10);
        }
      }
      tryInit();
    }
    
    // Inject CSS and wait for it to load before injecting HTML
    injectCSS(assetsBaseUrl + 'main.css?v=' + version)
      .then(function() {
        // CSS is loaded, now inject HTML content
        injectHTML(PRECACHED_HTML);
        // Initialize TopNavBar after HTML is injected
        initTopNavBar();
      })
      .catch(function(error) {
        // Even if CSS fails to load, inject HTML anyway
        console.error('CSS loading error:', error);
        injectHTML(PRECACHED_HTML);
        // Initialize TopNavBar after HTML is injected (even if CSS failed)
        initTopNavBar();
      });
  }
  
  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize);
  } else {
    // DOM is already ready
    initialize();
  }
})();
